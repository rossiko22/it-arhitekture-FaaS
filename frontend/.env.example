# Copy to .env.local and fill in from your Supabase project (Settings → API).
VITE_SUPABASE_URL=https://YOUR_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_OR_PUBLISHABLE_KEY

# Base URL for the deployed Edge Functions.
# Local:   http://localhost:54321/functions/v1
# Hosted:  https://YOUR_REF.supabase.co/functions/v1
VITE_FUNCTIONS_URL=http://localhost:54321/functions/v1
