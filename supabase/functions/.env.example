# Local secrets for `supabase functions serve --env-file ./supabase/functions/.env.local`
# Copy to .env.local (gitignored). SUPABASE_URL / SUPABASE_ANON_KEY /
# SUPABASE_SERVICE_ROLE_KEY are injected automatically by the CLI.

WEBHOOK_SECRET=local-dev-secret

# Optional: real email delivery via Resend. Without it, the notification-worker
# logs notifications to the notifications_sent table instead.
# RESEND_API_KEY=re_xxx
# FROM_EMAIL=ReceiptVault <onboarding@resend.dev>
